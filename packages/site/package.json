{
  "name": "@sageveil/site",
  "version": "0.1.2",
  "private": true,
  "dependencies": {
    "@sageveil/palette": "workspace:*"
  },
  "nx": {
    "targets": {
      "generate-ports": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node tools/scripts/ports-manifest.mjs",
          "cwd": "{workspaceRoot}"
        }
      },
      "build": {
        "dependsOn": [
          "generate-ports"
        ],
        "inputs": [
          "production",
          "^production",
          {
            "env": "BASE_PATH"
          }
        ]
      },
      "serve": {
        "dependsOn": [
          "generate-ports"
        ]
      },
      "preview": {
        "dependsOn": [
          "generate-ports"
        ]
      }
    }
  }
}
