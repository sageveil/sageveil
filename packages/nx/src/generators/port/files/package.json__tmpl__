{
  "name": "@sageveil/<%= portName %>",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@sageveil/palette": "workspace:*"
  },
  "nx": {
    "targets": {
      "generate": {
        "outputs": [
          "{workspaceRoot}/dist/ports/<%= portName %>"
        ]
      },
      "clean": {}
    }
  }
}
