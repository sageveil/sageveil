{
  "name": "@sageveil/pi",
  "version": "0.2.6",
  "private": true,
  "type": "module",
  "dependencies": {
    "@sageveil/palette": "workspace:*"
  },
  "nx": {
    "targets": {
      "generate": {
        "outputs": [
          "{workspaceRoot}/dist/ports/pi"
        ]
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish",
        "dependsOn": [
          "generate"
        ],
        "options": {
          "packageRoot": "dist/ports/pi",
          "access": "public"
        }
      },
      "clean": {}
    }
  },
  "sageveil": {
    "displayName": "Pi Coding Agent",
    "description": "Sageveil TUI theme and statusline for Pi Coding Agent.",
    "tags": [
      "cli"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6"
  }
}
