{
  "name": "@sageveil/tmux",
  "version": "0.2.0-rc.0",
  "private": true,
  "type": "module",
  "sageveil": {
    "displayName": "tmux",
    "description": "Statusline and pane styling with Sageveil balance for tmux.",
    "tags": [
      "terminal",
      "multiplexer"
    ]
  },
  "dependencies": {
    "@sageveil/palette": "workspace:*"
  },
  "nx": {
    "targets": {
      "generate": {
        "outputs": [
          "{workspaceRoot}/dist/ports/tmux"
        ]
      },
      "clean": {}
    }
  }
}
