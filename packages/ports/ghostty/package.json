{
  "name": "@sageveil/ghostty",
  "version": "0.2.0-rc.1",
  "private": true,
  "type": "module",
  "sageveil": {
    "displayName": "Ghostty",
    "description": "Sageveil colors tuned for Ghostty's terminal rendering.",
    "tags": [
      "terminal",
      "emulator"
    ]
  },
  "dependencies": {
