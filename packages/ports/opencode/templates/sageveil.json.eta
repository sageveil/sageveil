{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "<%= it.ansi.base.black %>",
    "surface": "<%= it.extras.surface %>",
    "overlay": "<%= it.extras.overlay %>",
    "border": "<%= it.extras.border %>",
    "dim": "<%= it.extras.dim %>",
    "muted": "<%= it.extras.muted %>",
    "text": "<%= it.ansi.base.white %>",
    "red": "<%= it.ansi.base.red %>",
    "green": "<%= it.ansi.base.green %>",
    "yellow": "<%= it.ansi.base.yellow %>",
    "blue": "<%= it.ansi.base.blue %>",
    "magenta": "<%= it.ansi.base.magenta %>",
    "brightGreen": "<%= it.ansi.bright.green %>",
    "brightYellow": "<%= it.ansi.bright.yellow %>",
    "brightBlue": "<%= it.ansi.bright.blue %>",
    "brightMagenta": "<%= it.ansi.bright.magenta %>"
  },
  "theme": {
    "primary": "brightMagenta",
    "secondary": "brightBlue",
    "accent": "magenta",
    "error": "red",
    "warning": "yellow",
    "success": "green",
    "info": "blue",
    "text": "text",
    "textMuted": "muted",
    "background": "black",
    "backgroundPanel": "surface",
    "backgroundElement": "overlay",
    "border": "border",
    "borderActive": "dim",
    "borderSubtle": "surface",
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": "muted",
    "diffHunkHeader": "blue",
    "diffHighlightAdded": "brightGreen",
    "diffHighlightRemoved": "red",
    "diffAddedBg": "surface",
    "diffRemovedBg": "surface",
    "diffContextBg": "black",
    "diffLineNumber": "dim",
    "diffAddedLineNumberBg": "surface",
    "diffRemovedLineNumberBg": "surface",
    "markdownText": "text",
    "markdownHeading": "brightBlue",
    "markdownLink": "blue",
    "markdownLinkText": "blue",
    "markdownCode": "brightGreen",
    "markdownBlockQuote": "muted",
    "markdownEmph": "yellow",
    "markdownStrong": "brightYellow",
    "markdownHorizontalRule": "border",
    "markdownListItem": "brightBlue",
    "markdownListEnumeration": "blue",
    "markdownImage": "blue",
    "markdownImageText": "blue",
    "markdownCodeBlock": "text",
    "syntaxComment": "dim",
    "syntaxKeyword": "blue",
    "syntaxFunction": "brightGreen",
    "syntaxVariable": "text",
    "syntaxString": "green",
    "syntaxNumber": "magenta",
    "syntaxType": "blue",
    "syntaxOperator": "blue",
    "syntaxPunctuation": "text"
  }
}
