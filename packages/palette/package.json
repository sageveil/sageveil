{
  "name": "@sageveil/palette",
  "version": "0.2.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sageveil/sageveil.git",
    "directory": "packages/palette"
  },
  "homepage": "https://github.com/sageveil/sageveil/tree/main/packages/palette",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm nx run palette:build"
  },
  "dependencies": {},
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "main": "packages/palette/src/index.ts",
          "rootDir": "packages/palette/src",
          "outputPath": "packages/palette/dist",
          "tsConfig": "packages/palette/tsconfig.lib.json",
          "generatePackageJson": false
        }
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish",
        "dependsOn": [
          "build"
        ],
        "options": {
          "packageRoot": "packages/palette",
          "access": "public"
        }
      }
    }
  }
}
